---
// Terminal-style code panel with traffic-light header dots.
// Inspired by reference design — for surfacing real schema / sample data.
interface Props {
  caption: string;
}
const { caption } = Astro.props;
---

<div class="overflow-hidden rounded-lg border border-white/10 bg-[#0a1428]">
  <div class="flex min-w-0 items-center justify-between gap-3 border-b border-white/10 bg-white/5 px-4 py-2.5">
    <div class="flex shrink-0 gap-1.5" aria-hidden="true">
      <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-amber-400/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
    </div>
    <span class="min-w-0 truncate font-mono text-[11px] text-white/60 sm:text-xs">{caption}</span>
  </div>
  <div class="overflow-x-auto p-4 font-mono text-[12px] leading-7 text-white/90 sm:p-5 sm:text-[13px]">
    <slot />
  </div>
</div>

---
import type { SiteCopy } from "@/lib/i18n";
import { switchLocalePath } from "@/lib/i18n";
import { Icon } from "astro-icon/components";

interface Props {
  copy: SiteCopy;
  currentPath: string;
}

const { copy, currentPath } = Astro.props;
const alternateLocale = copy.locale === "en" ? "zh-Hant" : "en";
const alternateHref = switchLocalePath(currentPath, alternateLocale);
const alternateLabel = copy.locale === "en" ? "繁" : "EN";
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-brand-navy/95 text-white backdrop-blur">
  <div class="section-shell flex items-center justify-between gap-3 py-4 sm:gap-4">
    <a href={copy.nav[0]?.href ?? "/"} class="flex min-w-0 items-center gap-3">
      <img
        src="/images/brand/logo.jpg"
        alt={copy.siteName}
        width="44"
        height="44"
        class="h-10 w-10 shrink-0 rounded-full object-cover sm:h-11 sm:w-11"
      />
      <div class="min-w-0">
        <p class="truncate text-base font-bold tracking-wide sm:text-lg">{copy.siteName}</p>
        <p class="hidden truncate text-xs text-white/70 sm:block">{copy.titleSuffix}</p>
      </div>
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        copy.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm font-medium transition hover:text-brand-gold",
              currentPath === item.href || currentPath === `${item.href}/`
                ? "text-brand-gold"
                : "text-white/85",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <a href={alternateHref} class="hidden text-sm text-white/80 hover:text-white sm:inline">
        <span class="font-semibold text-brand-gold">{alternateLabel}</span>
      </a>
      <button
        type="button"
        class="btn-primary hidden sm:inline-flex"
        data-lead-intent="request-info"
      >
        {copy.cta.requestInfo}
      </button>
      <button
        type="button"
        class="btn-secondary inline-flex items-center justify-center px-3 py-2 lg:hidden"
        data-mobile-nav-toggle
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label={copy.locale === "zh-Hant" ? "選單" : "Menu"}
      >
        <Icon name="lucide:menu" class="h-5 w-5" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-white/10 lg:hidden">
    <nav class="section-shell flex flex-col gap-3 py-4" aria-label="Mobile">
      {
        copy.nav.map((item) => (
          <a href={item.href} class="text-sm font-medium text-white/90 hover:text-brand-gold">
            {item.label}
          </a>
        ))
      }
      <a href={alternateHref} class="text-sm text-white/80">
        {alternateLabel}
      </a>
      <button type="button" class="btn-primary w-full" data-lead-intent="request-info">
        {copy.cta.requestInfo}
      </button>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-mobile-nav-toggle]");
  const mobileNav = document.getElementById("mobile-nav");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    mobileNav?.classList.toggle("hidden");
  });
</script>

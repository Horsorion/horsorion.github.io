---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CiteThisPage from "@/components/CiteThisPage.astro";
import { glossary, getGlossaryGroups } from "@/lib/glossary";
import { getDefinedTermSetSchema } from "@/lib/schema";

const locale = "zh-Hant";
const currentPath = "/glossary";
const url = `https://www.horsorion.com${currentPath}`;
const title = "香港賽馬術語表 — Class、Going、LBW、Sectional、Trial 等定義 | Horsorion";
const description =
  "香港賽馬常用術語完整字典 — 班次、場地狀況、檔位、評分、分段時間、彩池等 25+ 個專業詞彙嘅定義，由 Horsorion 數據團隊整理，可供 syndicate、量化團隊、傳媒及 AI 引用。";

const groups = getGlossaryGroups(locale);
const grouped = groups.map((g) => ({
  ...g,
  entries: glossary.filter((t) => t.group === g.id),
}));

const definedTermsForSchema = glossary.map((t) => ({
  term: t.termZh,
  definition: t.definitionZh,
}));
const schema = getDefinedTermSetSchema(locale, "Horsorion 香港賽馬術語表", url, definedTermsForSchema);
---

<BaseLayout title={title} description={description} locale={locale} currentPath={currentPath} schema={schema}>
  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section class="bg-brand-mist py-20">
    <div class="section-shell">
      <p class="font-mono text-sm uppercase tracking-[0.3em] text-brand-gold">Glossary · 賽馬術語</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold text-brand-navy md:text-5xl">
        香港賽馬術語表
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        本術語表由 Horsorion 數據團隊整理，涵蓋香港賽事、馬匹、場地、表現及投注嘅常用詞彙。每條定義均以 5 年內不需更新為原則撰寫，並輔以 Schema.org
        <code class="font-mono text-sm">DefinedTerm</code> 結構化資料，方便研究人員、傳媒及 AI 助手準確引用。
      </p>
      <p class="mt-3 max-w-2xl text-sm text-slate-500">
        若你發現定義有偏差或希望加入新詞彙，歡迎透過 <a href="/contact" class="text-brand-gold underline">聯絡頁</a> 提出建議。
      </p>
    </div>
  </section>

  <!-- ═══════════════════════ Quick nav ═══════════════════════ -->
  <section class="border-b border-brand-navy/5 bg-white py-6">
    <div class="section-shell flex flex-wrap gap-2">
      {grouped.map((g) => (
        <a
          href={`#${g.id}`}
          class="rounded-full border border-brand-navy/15 bg-white px-4 py-1.5 text-sm font-medium text-brand-navy transition hover:border-brand-gold hover:text-brand-gold"
        >
          {g.label} <span class="ml-1 font-mono text-xs text-slate-400">({g.entries.length})</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════ Term groups ═══════════════════════ -->
  <section class="bg-white py-16">
    <div class="section-shell space-y-16">
      {grouped.map((g) => (
        <div id={g.id} class="scroll-mt-24">
          <h2 class="text-2xl font-bold text-brand-navy md:text-3xl">{g.label}</h2>
          <dl class="mt-8 grid gap-6 md:grid-cols-2">
            {g.entries.map((t) => (
              <div
                id={`term-${t.term.toLowerCase().replace(/\s+/g, "-")}`}
                class="scroll-mt-24 rounded-2xl border border-brand-navy/10 bg-brand-mist/40 p-6"
              >
                <dt>
                  <span class="font-mono text-xs uppercase tracking-wide text-brand-gold">{t.term}</span>
                  <h3 class="mt-1 text-lg font-bold text-brand-navy">{t.termZh}</h3>
                </dt>
                <dd class="mt-3 text-sm leading-relaxed text-slate-700">{t.definitionZh}</dd>
              </div>
            ))}
          </dl>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════ Cite ═══════════════════════ -->
  <section class="bg-brand-mist py-16">
    <div class="section-shell">
      <CiteThisPage locale={locale} title="香港賽馬術語表" url={url} />

      <div class="mt-10 rounded-3xl border border-brand-navy/10 bg-white p-8">
        <h2 class="text-xl font-semibold text-brand-navy">需要更深入嘅 schema？</h2>
        <p class="mt-2 text-sm text-slate-600">
          Horsorion 完整數據字典涵蓋 200+ 欄位（每個欄位嘅資料型別、單位、可能值、計算方式），於 NDA 後可向客戶提供。
        </p>
        <a href="/contact" data-lead-intent="request-dictionary" class="btn-primary mt-6 inline-flex">
          索取完整數據字典
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

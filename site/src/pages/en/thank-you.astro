---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getWhatsappHref } from "@/lib/whatsapp";

const whatsappHref = getWhatsappHref();
---

<BaseLayout
  title="Thank you | Horsorion"
  description="We've received your enquiry and will reply within 24 hours."
  locale="en"
  currentPath="/en/thank-you"
  noindex={true}
>
  <section class="section-shell flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <div class="flex h-20 w-20 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
      <Icon name="lucide:check-circle-2" class="h-10 w-10" aria-hidden="true" />
    </div>
    <h1 class="mt-6 text-3xl font-bold text-brand-navy">Thanks for reaching out!</h1>
    <p class="mt-4 max-w-lg text-slate-600">
      We've received your information and typically reply within <strong>24 hours</strong>. For urgent requests, WhatsApp is fastest.
    </p>

    <div class="mt-10 grid w-full max-w-md gap-4">
      <div class="flex items-start gap-4 rounded-2xl border border-brand-navy/10 bg-white p-5 text-left">
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-brand-navy/8 text-brand-navy">
          <Icon name="lucide:mail" class="h-4 w-4" aria-hidden="true" />
        </div>
        <div>
          <p class="font-semibold text-brand-navy">Email follow-up</p>
          <p class="mt-1 text-sm text-slate-600">Reply within 24 hours with schemas and sample data.</p>
        </div>
      </div>
      <div class="flex items-start gap-4 rounded-2xl border border-brand-navy/10 bg-white p-5 text-left">
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700">
          <Icon name="lucide:message-circle" class="h-4 w-4" aria-hidden="true" />
        </div>
        <div>
          <p class="font-semibold text-brand-navy">Faster via WhatsApp</p>
          <p class="mt-1 text-sm text-slate-600">
            Urgent?
            <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-navy underline hover:no-underline">Message us on WhatsApp</a>.
          </p>
        </div>
      </div>
      <div class="flex items-start gap-4 rounded-2xl border border-brand-navy/10 bg-white p-5 text-left">
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-brand-gold/20 text-brand-navy">
          <Icon name="lucide:download" class="h-4 w-4" aria-hidden="true" />
        </div>
        <div>
          <p class="font-semibold text-brand-navy">Download a sample now</p>
          <p class="mt-1 text-sm text-slate-600">
            <a href="/samples/horsorion-sample-2025-07-16.csv" download class="font-semibold text-brand-navy underline hover:no-underline">Race-day sample CSV</a> (Happy Valley 2025-07-16, evaluation use)
          </p>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/en" class="btn-primary">Back to home</a>
      <a href="/en/data" class="btn-outline">View data catalogue</a>
    </div>
  </section>
</BaseLayout>

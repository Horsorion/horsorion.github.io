---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CiteThisPage from "@/components/CiteThisPage.astro";
import { glossary, getGlossaryGroups } from "@/lib/glossary";
import { getDefinedTermSetSchema } from "@/lib/schema";

const locale = "en";
const currentPath = "/en/glossary";
const url = `https://www.horsorion.com${currentPath}`;
const title = "Hong Kong Horse Racing Glossary — Class, Going, LBW, Sectional Times | Horsorion";
const description =
  "Plain-English definitions of 25+ Hong Kong horse racing terms — Class, Going, Draw, Rating, Sectional Time, LBW, Quinella, Trio and more. Curated by the Horsorion data team and machine-readable via Schema.org DefinedTerm.";

const groups = getGlossaryGroups(locale);
const grouped = groups.map((g) => ({
  ...g,
  entries: glossary.filter((t) => t.group === g.id),
}));

const definedTermsForSchema = glossary.map((t) => ({
  term: t.term,
  definition: t.definition,
}));
const schema = getDefinedTermSetSchema(
  locale,
  "Horsorion Hong Kong Horse Racing Glossary",
  url,
  definedTermsForSchema,
);
---

<BaseLayout title={title} description={description} locale={locale} currentPath={currentPath} schema={schema}>
  <!-- HERO -->
  <section class="bg-brand-mist py-20">
    <div class="section-shell">
      <p class="font-mono text-sm uppercase tracking-[0.3em] text-brand-gold">Glossary</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold text-brand-navy md:text-5xl">
        Hong Kong Horse Racing Glossary
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        Plain-English definitions of the most common Hong Kong horse racing terms — written by
        the Horsorion data team, reviewed against HKJC public usage, and designed to remain
        accurate for years. Each entry is exposed as a Schema.org
        <code class="font-mono text-sm">DefinedTerm</code> so research tools and AI assistants
        can quote it precisely.
      </p>
      <p class="mt-3 max-w-2xl text-sm text-slate-500">
        Spotted an error or need a term added? <a href="/en/contact" class="text-brand-gold underline">Contact us</a>.
      </p>
    </div>
  </section>

  <!-- Quick nav -->
  <section class="border-b border-brand-navy/5 bg-white py-6">
    <div class="section-shell flex flex-wrap gap-2">
      {grouped.map((g) => (
        <a
          href={`#${g.id}`}
          class="rounded-full border border-brand-navy/15 bg-white px-4 py-1.5 text-sm font-medium text-brand-navy transition hover:border-brand-gold hover:text-brand-gold"
        >
          {g.label} <span class="ml-1 font-mono text-xs text-slate-400">({g.entries.length})</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Term groups -->
  <section class="bg-white py-16">
    <div class="section-shell space-y-16">
      {grouped.map((g) => (
        <div id={g.id} class="scroll-mt-24">
          <h2 class="text-2xl font-bold text-brand-navy md:text-3xl">{g.label}</h2>
          <dl class="mt-8 grid gap-6 md:grid-cols-2">
            {g.entries.map((t) => (
              <div
                id={`term-${t.term.toLowerCase().replace(/\s+/g, "-")}`}
                class="scroll-mt-24 rounded-2xl border border-brand-navy/10 bg-brand-mist/40 p-6"
              >
                <dt>
                  <span class="font-mono text-xs uppercase tracking-wide text-brand-gold">{t.termZh}</span>
                  <h3 class="mt-1 text-lg font-bold text-brand-navy">{t.term}</h3>
                </dt>
                <dd class="mt-3 text-sm leading-relaxed text-slate-700">{t.definition}</dd>
              </div>
            ))}
          </dl>
        </div>
      ))}
    </div>
  </section>

  <!-- Cite -->
  <section class="bg-brand-mist py-16">
    <div class="section-shell">
      <CiteThisPage locale={locale} title="Hong Kong Horse Racing Glossary" url={url} />

      <div class="mt-10 rounded-3xl border border-brand-navy/10 bg-white p-8">
        <h2 class="text-xl font-semibold text-brand-navy">Need the full data dictionary?</h2>
        <p class="mt-2 text-sm text-slate-600">
          Horsorion's full data dictionary covers 200+ columns (data type, unit, allowed values,
          derivation rules) and is shared with clients under NDA.
        </p>
        <a href="/en/contact" data-lead-intent="request-dictionary" class="btn-primary mt-6 inline-flex">
          Request data dictionary
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

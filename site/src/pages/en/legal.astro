---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getWhatsappHref } from "@/lib/whatsapp";

const ndaWhatsappHref = getWhatsappHref("Hi Horsorion, I'd like to discuss NDA terms");
---

<BaseLayout
  title="Legal & NDA — Hong Kong Data Usage Terms | Horsorion"
  description="Horsorion legal page: mutual NDA process, data usage summary, liability terms, and Hong Kong SAR governing law. All commercial discussions begin under NDA."
  locale="en"
  currentPath="/en/legal"
>
  <section class="bg-brand-navy py-14 text-white">
    <div class="section-shell">
      <p class="eyebrow">Legal</p>
      <h1 class="mt-4 text-3xl font-bold">Legal documents & NDA</h1>
      <p class="mt-3 max-w-2xl text-white/80">
        All commercial engagements are conducted under a non-disclosure agreement. The summary below covers the
        scope and governing law — full clauses are shared during formal negotiation.
      </p>
    </div>
  </section>

  <section class="section-shell py-14">
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- NDA — contact-gated, no download -->
      <div class="surface-card">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-navy text-brand-gold">
            <Icon name="lucide:file-lock" class="h-5 w-5" aria-hidden="true" />
          </div>
          <h2 class="text-xl font-bold text-brand-navy">Non-disclosure agreement (NDA)</h2>
        </div>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Before commercial discussions we sign a mutual NDA — data samples, pricing, and customised proposals
          are then released. Clauses can be adapted to your compliance requirements.
        </p>
        <ul class="mt-4 space-y-2 text-sm text-slate-600">
          {[
            "Covers confidentiality, non-redistribution, and use limitations",
            "Governed by Hong Kong law, Hong Kong court jurisdiction",
            "Mutual: we can sign your in-house NDA template, or use ours",
            "Full data samples and proposal materials within 24 h of signing",
          ].map((item) => (
            <li class="flex items-start gap-2">
              <Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" aria-hidden="true" />
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-6 flex flex-wrap gap-3">
          <button type="button" class="btn-primary" data-lead-intent="request-info">
            <Icon name="lucide:mail" class="mr-2 h-4 w-4" aria-hidden="true" />
            Email us about NDA
          </button>
          <a
            href={ndaWhatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline"
          >
            <Icon name="lucide:message-circle" class="mr-2 h-4 w-4" aria-hidden="true" />
            WhatsApp us
          </a>
        </div>
      </div>

      <div class="surface-card">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-navy text-brand-gold">
            <Icon name="lucide:scroll-text" class="h-5 w-5" aria-hidden="true" />
          </div>
          <h2 class="text-xl font-bold text-brand-navy">Data usage terms summary</h2>
        </div>
        <div class="mt-4 space-y-4 text-sm leading-7 text-slate-600">
          <div>
            <p class="font-semibold text-brand-navy">Permitted uses</p>
            <p>Data is licensed for contracted purposes only — internal modelling, backtesting, research, and specific commercial applications.</p>
          </div>
          <div>
            <p class="font-semibold text-brand-navy">Prohibited uses</p>
            <p>No redistribution, resale, public disclosure, or transfer to third parties without written authorisation.</p>
          </div>
          <div>
            <p class="font-semibold text-brand-navy">Sample data usage</p>
            <p>Free samples are provided for evaluation and non-commercial use only. Commercial deliveries follow contract terms.</p>
          </div>
          <div>
            <p class="font-semibold text-brand-navy">Governing law</p>
            <p>All contracts are governed by the laws of the Hong Kong SAR and subject to the jurisdiction of Hong Kong courts.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-2xl border border-brand-navy/10 bg-brand-slate p-6">
      <h2 class="text-xl font-bold text-brand-navy">Company information</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2 text-sm">
        {[
          { label: "Company name", value: "Horsorion" },
          { label: "Legal status", value: "Hong Kong Business Registration" },
          { label: "Founded", value: "2015" },
          { label: "Office", value: "Hong Kong SAR" },
          { label: "Email", value: "horsorion@gmail.com" },
          { label: "Legal enquiries", value: "Email subject: Legal Enquiry" },
        ].map((item) => (
          <div class="rounded-xl bg-white px-4 py-3">
            <p class="text-xs text-slate-500">{item.label}</p>
            <p class="font-medium text-brand-navy">{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

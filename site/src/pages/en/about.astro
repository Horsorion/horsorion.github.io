---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getAboutContent } from "@/lib/content";
import WorldMap from "@/components/WorldMap.astro";
import UnsplashPhoto from "@/components/UnsplashPhoto.astro";
import { unsplashImages } from "@/lib/unsplash-images";

const locale = "en";
const content = getAboutContent(locale);
---

<BaseLayout
  title="About Horsorion — Hong Kong Horse Racing Data Infrastructure for Syndicates Worldwide"
  description="Horsorion was founded by a Hong Kong quant modelling team to turn HKJC public and derived data into a cleaned, point-in-time, queryable platform. Today we serve syndicates, quant funds, and analytics teams across the UK, US, mainland China, Hong Kong, and Australia."
  locale={locale}
  currentPath="/en/about"
>
  <section class="bg-brand-navy py-16 text-white">
    <div class="section-shell text-left">
      <p class="eyebrow">About Horsorion</p>
      <h1 class="mt-4 text-4xl font-bold">Hong Kong racing data, built for professionals</h1>
      <p class="mt-4 max-w-3xl text-lg text-white/80">
        {content.intro}
      </p>
    </div>
  </section>

  <!-- STORY -->
  <section class="section-shell py-14">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
        <p class="eyebrow text-brand-navy">Our story</p>
        <h2 class="mt-3 text-3xl font-bold text-brand-navy">Why we built Horsorion</h2>
        <div class="mt-5 space-y-4 text-sm leading-8 text-slate-600">
          <p>
            Hong Kong horse racing is one of Asia's most mature betting markets, with 700+ races each season and
            total annual turnover in the hundreds of billions of HKD. Yet for syndicates and quant teams, clean,
            standardised historical data has long been the single biggest bottleneck.
          </p>
          <p>
            Horsorion was founded by a Hong Kong-based quantitative modelling team with one goal: deliver HK
            racing data truly suitable for modelling — not raw scraper output. We built the full pipeline
            in-house, cross-validating against public sources and storing every record under point-in-time
            principles so your backtests stay clean of look-ahead bias.
          </p>
          <p>
            We deliberately keep a low profile. Client identities, team composition, and pricing are all handled
            under NDA. Reach out via email or WhatsApp and we will engage on terms you are comfortable with.
          </p>
        </div>
      </div>
      <div class="grid gap-4">
        {[
          { icon: "lucide:map-pin", label: "Headquarters", value: "Hong Kong SAR" },
          { icon: "lucide:building", label: "Legal status", value: "HK Business Registration" },
          { icon: "lucide:database", label: "Data history", value: "1980 – Today" },
          { icon: "lucide:refresh-cw", label: "Update cadence", value: "Race-day T+0" },
          { icon: "lucide:globe", label: "Serving regions", value: "APAC · Europe · Americas" },
          { icon: "lucide:shield", label: "Engagement", value: "NDA-backed commercial terms" },
        ].map((item) => (
          <div class="flex items-center gap-4 rounded-xl border border-brand-navy/10 bg-white px-5 py-3.5">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-brand-navy/8 text-brand-navy">
              <Icon name={item.icon} class="h-4 w-4" aria-hidden="true" />
            </div>
            <div>
              <p class="text-xs text-slate-500">{item.label}</p>
              <p class="font-semibold text-brand-navy">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ EDITORIAL PHOTO STRIP ═══════════════════════ -->
  <div class="relative h-[420px] overflow-hidden">
    <UnsplashPhoto
      image={unsplashImages["racecourse-aerial"]}
      class="absolute inset-0 h-full w-full"
      imgClass="h-full w-full object-cover object-[50%_30%]"
      alt="Racecourse grandstand — aerial view"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-navy/20 via-brand-navy/55 to-brand-navy/85"></div>
    <div class="relative flex h-full flex-col items-start justify-center section-shell">
      <p class="font-mono text-xs uppercase tracking-widest text-brand-gold/80">Global reach · Since 2015</p>
      <p class="mt-4 max-w-2xl font-display text-3xl font-bold leading-snug text-white sm:text-4xl">
        40 years of race records.<br />Serving syndicates across APAC, Europe, and the Americas.
      </p>
      <p class="mt-4 font-mono text-[10px] text-white/30">
        Photo: <a href={unsplashImages["racecourse-aerial"].credit.photoUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white/50">{unsplashImages["racecourse-aerial"].credit.name}</a> / Unsplash
      </p>
    </div>
  </div>

  <!-- GLOBAL CLIENT REACH -->
  <div class="bg-brand-slate">
    <WorldMap locale={locale} />
  </div>

  <!-- VALUES / PROOF -->
  <section class="section-shell py-14">
    <p class="eyebrow text-brand-navy">What sets us apart</p>
    <h2 class="mt-3 text-3xl font-bold text-brand-navy">How we engineer the data</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {[
        {
          icon: "lucide:database",
          title: "Point-in-time storage",
          body: "Every record is timestamped at publish moment. Backtests automatically lock the window — no look-ahead bias.",
        },
        {
          icon: "lucide:git-pull-request",
          title: "Schema stability promise",
          body: "Historical columns never change. New columns ship as additive versions, so your pipeline never breaks on upgrade.",
        },
        {
          icon: "lucide:check-circle-2",
          title: "Multi-source validation",
          body: "Every race is reconciled against multiple independent sources plus manual spot-checks before release.",
        },
      ].map((item) => (
        <article class="surface-card flex flex-col gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-navy text-brand-gold">
            <Icon name={item.icon} class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-base font-semibold text-brand-navy">{item.title}</h3>
          <p class="text-sm leading-7 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy py-14 text-white">
    <div class="section-shell text-center">
      <h2 class="text-3xl font-bold">Ready to talk?</h2>
      <p class="mt-4 mx-auto max-w-xl text-sm text-white/80">Request schemas, samples, or a tailored proposal — we reply within 24 hours.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <button type="button" class="btn-primary" data-lead-intent="request-info">
          Request information
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

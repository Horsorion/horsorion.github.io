---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CiteThisPage from "@/components/CiteThisPage.astro";
import { getPlaceSchema, getDatasetSchema } from "@/lib/schema";

const locale = "en";
const currentPath = "/en/courses/sha-tin";
const url = `https://www.horsorion.com${currentPath}`;
const title = "Sha Tin Racecourse Data — Turf 1,800m & Polytrack 1,551m | Horsorion";
const description =
  "Sha Tin Racecourse (ST) data coverage by Horsorion: turf circumference 1,800 m, all-weather Polytrack 1,551 m, race distances 1,000–2,400 m. Historical coverage of cards, results, sectional times, and final odds since the 1980s.";

const placeSchema = getPlaceSchema({
  name: "Sha Tin Racecourse",
  description: "Sha Tin Racecourse — Hong Kong Jockey Club's flagship racecourse, opened in 1978. Turf circumference 1,800 m and all-weather Polytrack 1,551 m. Hosts most weekend day meetings.",
  url,
  latitude: 22.4017,
  longitude: 114.2067,
  addressLocality: "Sha Tin, New Territories, Hong Kong",
});

const datasetSchema = getDatasetSchema(locale, {
  name: "Horsorion Sha Tin Racecourse Historical Race Dataset",
  description:
    "Covers every official race at Hong Kong's Sha Tin Racecourse on both turf and all-weather (Polytrack) surfaces from the 1980s to today, including racecards, results, sectional times, final odds, and tote pool data.",
  url,
  keywords: ["Sha Tin", "Hong Kong horse racing", "HKJC", "Polytrack", "racecard", "sectional time"],
  temporalStart: "1980",
  accessMode: "contact",
});

const facts = [
  { k: "Venue code",            v: "ST" },
  { k: "Opened",                v: "1978" },
  { k: "Turf circumference",    v: "1,800 m" },
  { k: "All-weather track",     v: "1,551 m (Polytrack)" },
  { k: "Turf race distances",   v: "1,000 / 1,200 / 1,400 / 1,600 / 1,800 / 2,000 / 2,200 / 2,400 m" },
  { k: "AWT race distances",    v: "1,200 / 1,650 / 1,800 / 2,000 m" },
  { k: "Meeting profile",       v: "Mostly weekend day meetings; occasional midweek twilight cards" },
  { k: "Horsorion data start",  v: "1980s (varies by product)" },
];
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  currentPath={currentPath}
  schema={[placeSchema, datasetSchema]}
>
  <section class="bg-brand-navy py-20 text-white">
    <div class="section-shell">
      <p class="font-mono text-sm uppercase tracking-[0.3em] text-brand-gold">Sha Tin Racecourse</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold md:text-5xl">Sha Tin Racecourse data</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/80">
        Sha Tin Racecourse (ST) is the larger of Hong Kong Jockey Club's two
        venues and the host of most weekend day meetings. This page documents
        Horsorion's coverage depth and the venue facts that shape how the data
        should be interpreted in models.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="section-shell grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-bold text-brand-navy">Venue facts</h2>
        <dl class="mt-6 divide-y divide-brand-navy/10 rounded-2xl border border-brand-navy/10 bg-brand-mist/40">
          {facts.map((f) => (
            <div class="grid grid-cols-1 gap-2 px-6 py-4 sm:grid-cols-3">
              <dt class="font-mono text-xs uppercase tracking-wide text-brand-gold sm:col-span-1">{f.k}</dt>
              <dd class="text-sm text-slate-700 sm:col-span-2">{f.v}</dd>
            </div>
          ))}
        </dl>

        <h2 class="mt-12 text-2xl font-bold text-brand-navy">Data notes</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-700">
          <li>· All Sha Tin races indexed as <code class="font-mono text-xs">race_id = ST-YYMMDD-NN</code></li>
          <li>· Turf and all-weather races flagged separately (<code class="font-mono text-xs">surface = TURF / AWT</code>)</li>
          <li>· Sectionals: 200 m intervals on turf, 400 m intervals on all-weather</li>
          <li>· Going Allowance combines HKJC public values with Horsorion's internal correction</li>
          <li>· Point-in-time racecards capture the last pre-jump state to avoid look-ahead bias</li>
        </ul>
      </div>

      <aside class="rounded-3xl border border-brand-navy/10 bg-brand-mist/40 p-6">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-brand-gold">Related</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="hover:text-brand-gold" href="/en/courses/happy-valley">→ Happy Valley Racecourse</a></li>
          <li><a class="hover:text-brand-gold" href="/en/coverage">→ Full coverage table</a></li>
          <li><a class="hover:text-brand-gold" href="/en/methodology/sectional-timing">→ Sectional timing methodology</a></li>
          <li><a class="hover:text-brand-gold" href="/en/glossary">→ Racing glossary</a></li>
          <li><a class="hover:text-brand-gold" href="/en/open-data">→ Free CSV sample</a></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="bg-brand-mist py-16">
    <div class="section-shell">
      <CiteThisPage locale={locale} title="Sha Tin Racecourse data" url={url} />
    </div>
  </section>
</BaseLayout>

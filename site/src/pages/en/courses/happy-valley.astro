---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CiteThisPage from "@/components/CiteThisPage.astro";
import { getPlaceSchema, getDatasetSchema } from "@/lib/schema";

const locale = "en";
const currentPath = "/en/courses/happy-valley";
const url = `https://www.horsorion.com${currentPath}`;
const title = "Happy Valley Racecourse Data — 1,450 m Turf, Night Racing | Horsorion";
const description =
  "Happy Valley Racecourse (HV) data coverage by Horsorion: 1,450 m turf circumference, midweek night-meeting venue. Historical coverage of racecards, results, sectional times, and final odds since the 1980s.";

const placeSchema = getPlaceSchema({
  name: "Happy Valley Racecourse",
  description: "Happy Valley Racecourse — Hong Kong's iconic city-centre turf racecourse. Established 1845, current configuration 1,450 m turf circumference. Hosts most midweek night meetings.",
  url,
  latitude: 22.2735,
  longitude: 114.1822,
  addressLocality: "Happy Valley, Hong Kong Island, Hong Kong",
});

const datasetSchema = getDatasetSchema(locale, {
  name: "Horsorion Happy Valley Racecourse Historical Race Dataset",
  description:
    "Covers every official race at Hong Kong's Happy Valley Racecourse from the 1980s to today, including racecards, results, sectional times, final odds, and tote pool data.",
  url,
  keywords: ["Happy Valley", "Hong Kong horse racing", "HKJC", "racecard", "sectional time", "night racing"],
  temporalStart: "1980",
  accessMode: "contact",
});

const facts = [
  { k: "Venue code",            v: "HV" },
  { k: "Established",           v: "1845" },
  { k: "Turf circumference",    v: "1,450 m (single turf course)" },
  { k: "Race distances",        v: "1,000 / 1,200 / 1,650 / 1,800 / 2,200 m" },
  { k: "Meeting profile",       v: "Predominantly midweek night meetings (Wednesday)" },
  { k: "Track character",       v: "Tight turns; favours front-runners and inside draws" },
  { k: "Horsorion data start",  v: "1980s (varies by product)" },
];
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  currentPath={currentPath}
  schema={[placeSchema, datasetSchema]}
>
  <section class="bg-brand-navy py-20 text-white">
    <div class="section-shell">
      <p class="font-mono text-sm uppercase tracking-[0.3em] text-brand-gold">Happy Valley Racecourse</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold md:text-5xl">Happy Valley Racecourse data</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/80">
        Happy Valley (HV) is Hong Kong's iconic city-centre night-racing venue,
        established in 1845. With a 1,450 m turf circumference and notably tight
        turns, race tempo and draw bias are uniquely strong here — and need to
        be modelled separately from Sha Tin.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="section-shell grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-bold text-brand-navy">Venue facts</h2>
        <dl class="mt-6 divide-y divide-brand-navy/10 rounded-2xl border border-brand-navy/10 bg-brand-mist/40">
          {facts.map((f) => (
            <div class="grid grid-cols-1 gap-2 px-6 py-4 sm:grid-cols-3">
              <dt class="font-mono text-xs uppercase tracking-wide text-brand-gold sm:col-span-1">{f.k}</dt>
              <dd class="text-sm text-slate-700 sm:col-span-2">{f.v}</dd>
            </div>
          ))}
        </dl>

        <h2 class="mt-12 text-2xl font-bold text-brand-navy">Data notes</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-700">
          <li>· Happy Valley races indexed as <code class="font-mono text-xs">race_id = HV-YYMMDD-NN</code></li>
          <li>· The short-circumference course makes <code class="font-mono text-xs">draw</code> one of the single most important features</li>
          <li>· Sectionals recorded every 200 m; pace profiles typically lean front-loaded</li>
          <li>· Night-time lighting and air temperature shifts are captured in the <code class="font-mono text-xs">weather</code> table</li>
        </ul>
      </div>

      <aside class="rounded-3xl border border-brand-navy/10 bg-brand-mist/40 p-6">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-brand-gold">Related</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="hover:text-brand-gold" href="/en/courses/sha-tin">→ Sha Tin Racecourse</a></li>
          <li><a class="hover:text-brand-gold" href="/en/coverage">→ Full coverage table</a></li>
          <li><a class="hover:text-brand-gold" href="/en/methodology/sectional-timing">→ Sectional timing methodology</a></li>
          <li><a class="hover:text-brand-gold" href="/en/glossary">→ Racing glossary</a></li>
          <li><a class="hover:text-brand-gold" href="/en/open-data">→ Free CSV sample</a></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="bg-brand-mist py-16">
    <div class="section-shell">
      <CiteThisPage locale={locale} title="Happy Valley Racecourse data" url={url} />
    </div>
  </section>
</BaseLayout>

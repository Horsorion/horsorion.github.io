---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CiteThisPage from "@/components/CiteThisPage.astro";
import StatusPill from "@/components/StatusPill.astro";
import { catalog, bucketLabelEn } from "@/lib/catalog";
import { getDatasetSchema } from "@/lib/schema";

const locale = "en";
const currentPath = "/en/coverage";
const url = `https://www.horsorion.com${currentPath}`;
const title = "Hong Kong Horse Racing Data Coverage — 40+ Years, 30,000+ Races, 8M+ Records | Horsorion";
const description =
  "Full transparency on Horsorion's Hong Kong horse racing dataset coverage: 30,000+ races, 16,000+ horses, and 8,000,000+ structured records across Sha Tin and Happy Valley from 1980 to today. Per-product depth and update cadence below.";

const facts = [
  { label: "Historical depth",  value: "1980 → Today",  hint: "Earliest data from the 1980s; some products start in the 2010s." },
  { label: "Structured records", value: "8,000,000+",   hint: "Across races, horses, sectionals, odds, vet, and more." },
  { label: "Races recorded",    value: "30,000+",        hint: "All official meetings plus most barrier trials." },
  { label: "Horses tracked",    value: "16,000+",        hint: "From debut through retirement." },
  { label: "Racecourses",       value: "2",              hint: "Sha Tin (ST) and Happy Valley (HV)." },
  { label: "Update cadence",    value: "Race-day T+0",    hint: "ETL fires immediately post-race; daily batch delivery." },
];

const datasetSchema = getDatasetSchema(locale, {
  name: "Horsorion Hong Kong Horse Racing Dataset",
  description:
    "Horsorion's Hong Kong horse racing dataset covers 1980 to today across 30,000+ races and 16,000+ horses, organised into Pre-Race, Post-Race, General, and Odds categories with 30+ data products. All historical records are stored under point-in-time discipline to prevent look-ahead bias in back-tests.",
  url,
  keywords: [
    "Hong Kong horse racing",
    "HKJC data",
    "Sha Tin",
    "Happy Valley",
    "sectional time",
    "tote odds",
    "race card",
    "point-in-time",
  ],
  temporalStart: "1980",
  variableMeasured: [
    "race_id", "race_date", "venue", "class", "distance", "going",
    "horse_id", "jockey", "trainer", "draw", "weight", "rating",
    "finish_position", "finish_time", "lbw", "sec_400m", "sec_600m",
    "win_odds", "place_odds", "quinella_odds", "tote_pool",
  ],
  accessMode: "contact",
});
---

<BaseLayout title={title} description={description} locale={locale} currentPath={currentPath} schema={datasetSchema}>
  <section class="bg-brand-navy py-20 text-white">
    <div class="section-shell">
      <p class="font-mono text-sm uppercase tracking-[0.3em] text-brand-gold">Coverage</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold md:text-5xl">
        Hong Kong horse racing data coverage
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-white/80">
        Horsorion consolidates HKJC public and derived data into a single,
        structured, queryable platform. Below are every quantitative coverage
        metric we can disclose, so research teams can evaluate fit before contact.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="section-shell">
      <h2 class="text-2xl font-bold text-brand-navy md:text-3xl">Headline numbers</h2>
      <p class="mt-2 max-w-2xl text-sm text-slate-600">All figures audited internally and re-verified at the end of every HK racing season.</p>
      <dl class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {facts.map((f) => (
          <div class="rounded-2xl border border-brand-navy/10 bg-brand-mist/40 p-6">
            <dt class="font-mono text-xs uppercase tracking-wide text-brand-gold">{f.label}</dt>
            <dd class="mt-2 text-3xl font-extrabold text-brand-navy">{f.value}</dd>
            <p class="mt-2 text-xs text-slate-500">{f.hint}</p>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="bg-brand-mist py-16">
    <div class="section-shell">
      <h2 class="text-2xl font-bold text-brand-navy md:text-3xl">Coverage depth by product</h2>
      <p class="mt-2 max-w-2xl text-sm text-slate-600">
        Historical depth is bucketed using the earliest verifiable date in our data catalogue;
        actual datasets may begin earlier than the bucket suggests. Sample data and full schemas
        are shared with prospects after NDA.
      </p>

      {catalog.map((cat) => (
        <div class="mt-10 overflow-hidden rounded-3xl border border-brand-navy/10 bg-white shadow-sm">
          <div class="border-b border-brand-navy/10 bg-brand-navy px-6 py-4 text-white">
            <h3 class="text-lg font-bold">{cat.titleEn}</h3>
            <p class="mt-1 text-sm text-white/70">{cat.descriptionEn}</p>
          </div>
          <table class="w-full text-sm">
            <thead class="bg-brand-mist/60 font-mono text-xs uppercase tracking-wider text-slate-500">
              <tr>
                <th class="px-6 py-3 text-left">Product</th>
                <th class="px-6 py-3 text-left">Chinese</th>
                <th class="px-6 py-3 text-left">History</th>
                <th class="px-6 py-3 text-left">Cadence</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-brand-navy/5">
              {cat.products.map((p) => (
                <tr>
                  <td class="px-6 py-3 font-medium text-brand-navy">{p.nameEn}</td>
                  <td class="px-6 py-3 text-xs text-slate-500">{p.name}</td>
                  <td class="px-6 py-3 text-slate-700">{bucketLabelEn[p.historyBucket]}</td>
                  <td class="px-6 py-3"><StatusPill variant={p.status} /></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="section-shell">
      <h2 class="text-2xl font-bold text-brand-navy md:text-3xl">Racecourse coverage</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <a href="/en/courses/sha-tin" class="group block rounded-3xl border border-brand-navy/10 bg-brand-mist/40 p-8 transition hover:border-brand-gold">
          <p class="font-mono text-xs uppercase tracking-wide text-brand-gold">Sha Tin (ST)</p>
          <h3 class="mt-2 text-2xl font-bold text-brand-navy group-hover:text-brand-gold">Sha Tin Racecourse</h3>
          <p class="mt-3 text-sm text-slate-600">
            HKJC's flagship venue. Hosts both turf (1,800 m circumference) and all-weather (1,551 m, Polytrack) racing. Used for most weekend day meetings.
          </p>
          <p class="mt-4 font-mono text-xs text-brand-navy">→ See Sha Tin coverage detail</p>
        </a>
        <a href="/en/courses/happy-valley" class="group block rounded-3xl border border-brand-navy/10 bg-brand-mist/40 p-8 transition hover:border-brand-gold">
          <p class="font-mono text-xs uppercase tracking-wide text-brand-gold">Happy Valley (HV)</p>
          <h3 class="mt-2 text-2xl font-bold text-brand-navy group-hover:text-brand-gold">Happy Valley Racecourse</h3>
          <p class="mt-3 text-sm text-slate-600">
            City-centre night-racing venue, 1,450 m turf circumference. Tight turns and fast tempo materially shape race strategy.
          </p>
          <p class="mt-4 font-mono text-xs text-brand-navy">→ See Happy Valley coverage detail</p>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-brand-mist py-16">
    <div class="section-shell">
      <CiteThisPage locale={locale} title="Hong Kong horse racing data coverage" url={url} />

      <div class="mt-10 rounded-3xl border border-brand-navy/10 bg-white p-8">
        <h2 class="text-xl font-semibold text-brand-navy">Want to verify coverage yourself?</h2>
        <p class="mt-2 text-sm text-slate-600">
          We publish a free single-day race sample (CSV) so you can test density and structure immediately.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/en/open-data" class="btn-primary inline-flex">Download open sample</a>
          <a href="/en/contact" data-lead-intent="request-info" class="btn-secondary inline-flex">Request full coverage report</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

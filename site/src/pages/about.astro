---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getAboutContent } from "@/lib/content";
import WorldMap from "@/components/WorldMap.astro";
import UnsplashPhoto from "@/components/UnsplashPhoto.astro";
import { unsplashImages } from "@/lib/unsplash-images";

const locale = "zh-Hant";
const content = getAboutContent(locale);
---

<BaseLayout
  title="關於 Horsorion — 香港賽馬數據基礎建設供應商 | 服務全球 syndicate"
  description="Horsorion 由香港量化建模團隊創立，專注將 HKJC 公開及衍生數據整合為清洗、point-in-time、可回溯的資料平台，現服務分佈於英國、美國、中國、香港、澳洲的 syndicate、量化基金與分析團隊。"
  locale={locale}
  currentPath="/about"
>
  <section class="bg-brand-navy py-16 text-white">
    <div class="section-shell text-left">
      <p class="eyebrow">About Horsorion</p>
      <h1 class="mt-4 text-4xl font-bold">香港賽馬數據的專業夥伴</h1>
      <p class="mt-4 max-w-3xl text-lg text-white/80">
        {content.intro}
      </p>
    </div>
  </section>

  <!-- ═══════════════════════ STORY ═══════════════════════ -->
  <section class="section-shell py-14">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
        <p class="eyebrow text-brand-navy">Our story</p>
        <h2 class="mt-3 text-3xl font-bold text-brand-navy">為何創立 Horsorion</h2>
        <div class="mt-5 space-y-4 text-sm leading-8 text-slate-600">
          <p>
            香港賽馬是亞洲最成熟的博彩市場之一，每年超過 700 場賽事，彩池成交額以千億港元計。對 syndicate 與量化團隊而言，可靠、乾淨、標準化的歷史數據一直是核心痛點。
          </p>
          <p>
            Horsorion 由香港本地量化建模團隊創立，專注提供真正可用於建模的香港賽馬數據，而非未經處理的原始爬蟲輸出。我們自建完整數據 pipeline，從公開來源多重交叉驗證，並以 Point-in-Time (PIT) 原則儲存，確保回測不會受到 look-ahead bias 污染。
          </p>
          <p>
            我們刻意保持低調，客戶身份、團隊組成與定價方案均以保密協議 (NDA) 處理。歡迎透過電郵或 WhatsApp 與我們聯繫，將按閣下習慣的方式評估合適的合作模式。
          </p>
        </div>
      </div>
      <div class="grid gap-4">
        {[
          { icon: "lucide:map-pin", label: "總部", value: "香港特別行政區" },
          { icon: "lucide:building", label: "法律地位", value: "香港商業登記" },
          { icon: "lucide:database", label: "數據年份", value: "1980 – 至今" },
          { icon: "lucide:refresh-cw", label: "更新頻率", value: "賽馬日 T+0" },
          { icon: "lucide:globe", label: "服務地區", value: "亞太 · 歐洲 · 北美" },
          { icon: "lucide:shield", label: "合約形式", value: "支援 NDA 商業合作" },
        ].map((item) => (
          <div class="flex items-center gap-4 rounded-xl border border-brand-navy/10 bg-white px-5 py-3.5">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-brand-navy/8 text-brand-navy">
              <Icon name={item.icon} class="h-4 w-4" aria-hidden="true" />
            </div>
            <div>
              <p class="text-xs text-slate-500">{item.label}</p>
              <p class="font-semibold text-brand-navy">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ EDITORIAL PHOTO STRIP ═══════════════════════ -->
  <!-- Full-bleed, not a card — creates an editorial beat before the WorldMap -->
  <div class="relative h-[420px] overflow-hidden">
    <UnsplashPhoto
      image={unsplashImages["racecourse-aerial"]}
      class="absolute inset-0 h-full w-full"
      imgClass="h-full w-full object-cover object-[50%_30%]"
      alt="Racecourse grandstand — aerial view"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-navy/20 via-brand-navy/55 to-brand-navy/85"></div>
    <div class="relative flex h-full flex-col items-start justify-center section-shell">
      <p class="font-mono text-xs uppercase tracking-widest text-brand-gold/80">Global reach · Since 2015</p>
      <p class="mt-4 max-w-2xl font-display text-3xl font-bold leading-snug text-white sm:text-4xl">
        40 年賽事紀錄。<br />現服務於亞太、歐洲及北美的 syndicate。
      </p>
    </div>
  </div>

  <!-- ═══════════════════════ GLOBAL CLIENT REACH ═══════════════════════ -->
  <div class="bg-brand-slate">
    <WorldMap locale={locale} />
  </div>

  <!-- ═══════════════════════ VALUES / PROOF ═══════════════════════ -->
  <section class="section-shell py-14">
    <p class="eyebrow text-brand-navy">What sets us apart</p>
    <h2 class="mt-3 text-3xl font-bold text-brand-navy">我們的工程原則</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {[
        {
          icon: "lucide:database",
          title: "Point-in-Time 儲存",
          body: "每一筆數據均記錄發佈時刻，回測時自動鎖窗，杜絕 look-ahead bias。",
        },
        {
          icon: "lucide:git-pull-request",
          title: "Schema 穩定承諾",
          body: "歷史欄位保持不變，新增欄位以版本化方式擴展，避免影響既有 pipeline。",
        },
        {
          icon: "lucide:check-circle-2",
          title: "多源交叉驗證",
          body: "每場賽事數據經多個獨立來源比對，並加入人工抽查後才釋出。",
        },
      ].map((item) => (
        <article class="surface-card flex flex-col gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-navy text-brand-gold">
            <Icon name={item.icon} class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-base font-semibold text-brand-navy">{item.title}</h3>
          <p class="text-sm leading-7 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════ CTA ═══════════════════════ -->
  <section class="bg-brand-navy py-14 text-white">
    <div class="section-shell text-center">
      <h2 class="text-3xl font-bold">準備聯絡 Horsorion？</h2>
      <p class="mt-4 mx-auto max-w-xl text-sm text-white/80">索取 schema、樣本或方案資料，我們將於 1 個工作天內回覆。</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <button type="button" class="btn-primary" data-lead-intent="request-info">
          索取資料
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

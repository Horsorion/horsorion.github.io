---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
---

<BaseLayout
  title="404 — Horsorion"
  description="Page not found · 頁面不存在"
  locale="zh-Hant"
  currentPath="/404"
  noindex={true}
>
  <section class="section-shell flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <div class="flex h-20 w-20 items-center justify-center rounded-full bg-brand-slate text-brand-navy">
      <Icon name="lucide:file-question" class="h-10 w-10" aria-hidden="true" />
    </div>
    <h1 class="mt-6 text-5xl font-bold text-brand-navy">404</h1>
    <p class="mt-4 text-xl text-slate-600">找不到頁面 · Page not found</p>
    <p class="mt-3 max-w-md text-sm text-slate-500">
      你所訪問的頁面不存在或已移動。如需協助，請聯絡我們。
    </p>
    <p class="mt-2 max-w-md text-sm text-slate-500">
      The page you requested does not exist or has moved. Please contact us if you need help.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-primary">返回主頁 · Home (中文)</a>
      <a href="/en" class="btn-secondary">English home</a>
      <a href="/contact" class="btn-outline">聯絡 · Contact</a>
    </div>
  </section>
</BaseLayout>
